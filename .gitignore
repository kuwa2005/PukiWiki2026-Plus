# 機密・環境依存
.env
.env.*
!.env.example
pukiwiki/pukiwiki.ini.php

# Wiki データ（上書きデプロイで本番データを保護）
pukiwiki/wiki/
!pukiwiki/wiki/.htaccess
!pukiwiki/wiki/index.html

# ランタイム生成物・ユーザーコンテンツ
pukiwiki/cache/*
!pukiwiki/cache/.htaccess
!pukiwiki/cache/index.html
pukiwiki/backup/*
!pukiwiki/backup/.htaccess
!pukiwiki/backup/index.html
pukiwiki/attach/*
!pukiwiki/attach/.htaccess
!pukiwiki/attach/index.html
pukiwiki/diff/*
!pukiwiki/diff/.htaccess
!pukiwiki/diff/index.html
pukiwiki/counter/*
!pukiwiki/counter/.htaccess
!pukiwiki/counter/index.html

