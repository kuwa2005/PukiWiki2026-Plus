<?php
// PukiWiki2026 — 設定雛形（抜粋）
//
// 配置: pukiwiki/pukiwiki.ini.php（git 管理外）
// 使い方: 必要なブロックを pukiwiki.ini.php に反映する
// 詳細: docs/ANTI-SPAM.md, docs/SECURITY-AUDIT.md, docs/OEMBED.md
//
// ディレクトリ定数（SKIN_DIR / IMAGE_DIR 等）は上流同梱の pukiwiki.ini.php を
// 初回コピー後、index.php の DATA_HOME=pukiwiki/ に合わせて確認すること。

/////////////////////////////////////////////////
// 起動時ディレクトリパーミッション（Unix/Linux 本番向け）
// Windows 開発環境では自動スキップ。詳細: docs/DEPLOY.md §3.2
/////////////////////////////////////////////////

// $perm_check_on_boot = TRUE;   // FALSE で無効化
// $perm_dir_mode = 0777;        // 修正時のディレクトリ mode
// $perm_file_mode = 0666;        // 再帰修正時のファイル mode
// $perm_acceptable_dir_modes = array(0777, 0775, 0770);
// $perm_check_dirs_extra = array(); // 追加の定数名（通常不要）

/////////////////////////////////////////////////
// セキュリティ（PukiWiki2026 推奨既定）
/////////////////////////////////////////////////

// PKWK_SAFE_MODE=1 — #version 等の情報漏洩を抑制（SEC-M04）
// PKWK_DISABLE_INLINE_IMAGE_FROM_URI=1 — 外部画像ビーコン防止（SEC-L02）

// 管理者パスワード（必ず変更 — 初期値の使用禁止）
// ハッシュ生成: tools/gen-password-hash.php または docs/SETUP.md
// $adminpass = '{x-php-sha256}YOUR_HASH_HERE';

// 編集者（1件以上必須）
// 警告: 下記 editor / editor はデモ用初期値。**必ず変更してから使うこと。**
// 初回ログイン時にパスワード変更画面が表示されます（plugin/changepassword）。
$auth_users = array(
    'editor' => '{x-php-sha256}1553cc62ff246044c683a61e203e65541990e7fcd4af9443d22b9557ecc9ac54', // editor — 必ず変更
);

// 信頼プロキシ（HTTP_X_FORWARDED_USER 使用時のみ）
// $auth_trusted_proxies = array('127.0.0.1', '::1', '10.0.0.1');

// PKWK_UPDATE_EXEC を使う場合はホワイトリスト必須（SEC-C01）
// define('PKWK_UPDATE_EXEC', '/path/to/fixed/script.sh');
// define('PKWK_UPDATE_EXEC_ALLOWED', array('/path/to/fixed/script.sh'));

// セキュリティ HTTP ヘッダー（SEC-M06）
// $http_response_custom_headers = array(
//     'X-Content-Type-Options: nosniff',
//     'X-Frame-Options: SAMEORIGIN',
//     'Referrer-Policy: same-origin',
// );

/////////////////////////////////////////////////
// oEmbed — URL から外部コンテンツを埋め込み表示
/////////////////////////////////////////////////

$oembed_enabled = 1;
$oembed_standalone_url = 1;
$oembed_providers = array('youtube', 'vimeo', 'twitter', 'flickr');
$oembed_maxwidth = 640;
$oembed_maxheight = 480;
$oembed_cache_hours = 24;

/////////////////////////////////////////////////
// Akismet — 書き込み POST のスパム判定（docs/ANTI-SPAM.md）
/////////////////////////////////////////////////

$akismet_enabled = 0;           // 既定 OFF（ログイン必須運用では任意）
$akismet_api_key = '';          // Akismet API key（https://akismet.com/）
$akismet_blog_url = '';         // 空なら get_base_uri(PKWK_URI_ABSOLUTE) を使用
$akismet_strict = 0;            // 1=API エラー時も拒否, 0=エラー時は通す

/////////////////////////////////////////////////
// CAPTCHA — 編集フォーム（docs/ANTI-SPAM.md, SPAM-02）
/////////////////////////////////////////////////

$captcha_enabled = 0;           // 1=有効（reCAPTCHA 時は site/secret key も必須）
$captcha_provider = 'recaptcha_v2'; // recaptcha_v2 | recaptcha_v3 | honeypot
$recaptcha_site_key = '';
$recaptcha_secret_key = '';

/////////////////////////////////////////////////
// 外部リンク POST 制限（docs/ANTI-SPAM.md, SPAM-04）
/////////////////////////////////////////////////

$spam_block_external_links = 0; // 0=無効, 1=全員拒否, 2=管理者のみ許可
$spam_external_link_allowlist = array(); // 例: array('example.com', 'youtube.com')
