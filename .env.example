# PukiWiki2026 Plus — FTP 自動デプロイ設定
# コピー: copy .env.example .env
# .env は git 管理外。パスワードをリポジトリにコミットしないこと。

# --- FTP 接続 ---
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=your_ftp_user
FTP_PASSWORD=your_ftp_password
# ftp | ftps（明示的 TLS / FTPES）| sftp
FTP_PROTOCOL=ftps

# リモート DocumentRoot（FTP ログイン直下からのパス。index.php を置くディレクトリ）
# 例: public_html/debugprint.com/pukiwiki
# 例: /virtual/pcm/public_html/debugprint.com/pukiwiki
FTP_REMOTE_DIR=public_html/debugprint.com/pukiwiki

# ローカル同期元（省略時はリポジトリルート）
# LOCAL_DIR=D:\00_project\pukiwiki2026 Plus

# WinSCP.com のパス（省略時は Program Files を自動検索）
# FTP_WINSCP_PATH=C:\Program Files\WinSCP\WinSCP.com
# WINSCP_PATH=  （FTP_WINSCP_PATH の別名としても可）

# --- 除外（安全）---
# 1 = pukiwiki/pukiwiki.ini.php を同期対象から除外（既定・推奨）
# 本番 ini は READONLY のため FTP 転送は失敗する。0 にしてもスクリプトは ini を転送しません。
FTP_EXCLUDE_INI=1
